' evento
Controls.ButtonClicked = AlHacerClick

Sub AlHacerClick
  ultimo_boton = Controls.LastClickedButton
  
  ' Lógica del botón Second
  If ultimo_boton = second Then
    IntercambiarBotones()
  ElseIf ultimo_boton = trigo Then
      IntercambiarBotones2()
  EndIf
  
'Números
  If ultimo_boton = uno Then
    boton1()
  ElseIf ultimo_boton = dos Then
    boton2()
  ElseIf ultimo_boton = tres Then
    boton3()
  ElseIf ultimo_boton = cuatro Then
    boton4()
  ElseIf ultimo_boton = cinco Then
    boton5()
  ElseIf ultimo_boton = seis Then
    boton6()
  ElseIf ultimo_boton = siete Then
    boton7()
  ElseIf ultimo_boton = ocho Then
    boton8()
  ElseIf ultimo_boton = nueve Then
    boton9()
  ElseIf ultimo_boton = cero Then
    boton0()
  EndIf
  
  'Especiales
  
  If ultimo_boton = cuadrado Then
    botoncuadrado()
  ElseIf ultimo_boton =  raiz2 then 
    botonraiz2()
  ElseIf ultimo_boton = potencia then
    botonpotencia()
  ElseIf ultimo_boton = potenciadies then
    botonpotenciadies()
  ElseIf ultimo_boton = log then
    botonlog()
  ElseIf ultimo_boton = ln then
    botonln()
  ElseIf ultimo_boton = fraccion then
    botonfraccion()
  ElseIf ultimo_boton = absoluto then
    botonabsoluto()
  ElseIf ultimo_boton = factorial then
    botonfactorial()
  EndIf
  'second 
  If ultimo_boton = cubo Then
    botoncubo()
  ElseIf ultimo_boton = raiz3 then
    botonraiz3()
  Elseif  ultimo_boton = raizy then
    botonraizy()
  elseif  ultimo_boton = potenciados then
    botonpotenciados()
  Elseif  ultimo_boton = logyx then
    botonlogy()
  ElseIf  ultimo_boton = ex then
    botonex()
  ElseIf ultimo_boton = fracciony then
    botonfracciony()
  EndIf
   
   'pi y eulet
   
   If ultimo_boton = pi Then
     botonpi()
   ElseIf ultimo_boton = e then
     botone()
   EndIf
   
   'TRIGO
   
   If ultimo_boton = cos Then
     botoncos()
   ElseIf ultimo_boton = anticos then
     botonanticos()
   ElseIf ultimo_boton = sen then
     botonsen()
   elseIf ultimo_boton = antisen then
    botonantisen() 
  elseIf ultimo_boton = tan then
    botontan()
  elseif ultimo_boton = antitan then
    botonantitan()
    EndIf
  

' Lógica de Operaciones Básicas
  If ultimo_boton = mas Then
    botonmas()
  ElseIf ultimo_boton = menos then
    botonresta()
  ElseIf ultimo_boton = Multiplicar then
    botonMultiplicacion()
  ElseIf ultimo_boton = dividido then
    botonDivision()
  ElseIf ultimo_boton = CE then
    botonBT()
  elseif ultimo_boton = C then  
    botonC()
  ElseIf ultimo_boton = igual then  
    botonIgual()
  ElseIf ultimo_boton = punto then
    botonpunto()
  EndIf
EndSub

Sub IntercambiarBotones
  If estadoSecond = 0 Then
    estadoSecond = 1
    Controls.HideControl(cuadrado)
    Controls.HideControl(raiz2)
    Controls.HideControl(potencia)
    Controls.HideControl(potenciadies)
    Controls.HideControl(log)
    Controls.HideControl(ln)
    Controls.HideControl(fraccion)
    Controls.ShowControl(cubo)
    Controls.ShowControl(raiz3)
    Controls.ShowControl(raizy)
    Controls.ShowControl(potenciados)
    Controls.ShowControl(logyx)
    Controls.ShowControl(ex)
    Controls.ShowControl(fracciony)
  Else
    estadoSecond = 0
    Controls.ShowControl(cuadrado)
    Controls.ShowControl(raiz2)
    Controls.ShowControl(potencia)
    Controls.ShowControl(potenciadies)
    Controls.ShowControl(log)
    Controls.ShowControl(ln)
    Controls.ShowControl(fraccion)
    Controls.HideControl(cubo)
    Controls.HideControl(raiz3)
    Controls.HideControl(raizy)
    Controls.HideControl(potenciados)
    Controls.HideControl(logyx)
    Controls.HideControl(ex)
    Controls.HideControl(fracciony)
  EndIf
EndSub
Sub IntercambiarBotones2
  If estadotrigo = 0 Then 
    estadotrigo = 1
    Controls.HideControl(cos)
    Controls.HideControl(anticos)
    Controls.ShowControl(sen)
    Controls.ShowControl(antisen)
    Controls.HideControl(tan)
    Controls.HideControl(antitan)
  ElseIf estadotrigo = 1 Then 
    estadotrigo = 2
    Controls.HideControl(cos)
    Controls.HideControl(anticos)
    Controls.HideControl(sen)
    Controls.HideControl(antisen)
    Controls.ShowControl(tan)
    Controls.ShowControl(antitan)
    
  ElseIf estadotrigo = 2 Then 
    estadotrigo = 0
    Controls.ShowControl(cos)
    Controls.ShowControl(anticos)
    Controls.HideControl(sen)
    Controls.HideControl(antisen)
    Controls.HideControl(tan)
    Controls.HideControl(antitan)
  EndIf
EndSub

' --- SUBRUTINAS DE NÚMEROS ---
