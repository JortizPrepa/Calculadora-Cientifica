'pi y eulet

Sub botonpi
  operador1 = 3.14159265358979
  Controls.SetTextBoxText(caja, Text.Append(Controls.GetTextBoxText(caja), operador1))
  Controls.SetTextBoxText(proceso, operador1)
EndSub
Sub botone 
  e = 2.718281828459045
  Controls.SetTextBoxText(caja, Text.Append(Controls.GetTextBoxText(caja), e))
  Controls.SetTextBoxText(proceso, e)
EndSub

'Trigonometria

Sub botoncos
  operador1 = Controls.GetTextBoxText(caja)
  total = Math.Cos(operador1)
  Controls.SetTextBoxText(proceso, "cos(" + operador1 + ") =")
  Controls.SetTextBoxText(caja, total)
EndSub
Sub botonsen
  operador1 = Controls.GetTextBoxText(caja)
  total = Math.Sin(operador1)
  Controls.SetTextBoxText(proceso, "sin(" + operador1 + ") =")
  Controls.SetTextBoxText(caja, total)
EndSub
Sub botontan
  operador1 = Controls.GetTextBoxText(caja)
  total = Math.Tan(operador1)
  Controls.SetTextBoxText(proceso, "tan(" + operador1 + ") =")
  Controls.SetTextBoxText(caja, total)
EndSub
Sub botonanticos
  operador1 = Controls.GetTextBoxText(caja)
  total = Math.ArcCos(operador1)
  Controls.SetTextBoxText(proceso, "cos⁻¹(" + operador1 + ") =")
  Controls.SetTextBoxText(caja, total)
EndSub
Sub botonantisen
  operador1 = Controls.GetTextBoxText(caja)
  total = Math.ArcSin(operador1)
  Controls.SetTextBoxText(proceso, "sen⁻¹(" + operador1 + ") =")
  Controls.SetTextBoxText(caja, total)
EndSub
Sub botonantitan
  operador1 = Controls.GetTextBoxText(caja)
  total = Math.ArcTan(operador1)
  Controls.SetTextBoxText(proceso, "tan⁻¹(" + operador1 + ") =")
  Controls.SetTextBoxText(caja, total)
EndSub


'Especiales
Sub botoncuadrado
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(proceso,operador1 + "² =")
  operador1 = operador1 * operador1
  Controls.SetTextBoxText(caja,operador1)

EndSub
Sub botonraiz2
  operador1 = Controls.GetTextBoxText(caja)
  operador2 = Math.SquareRoot(operador1)
  Controls.SetTextBoxText(caja,operador2)
  Controls.SetTextBoxText(proceso, "²√" + operador1 + " =")
EndSub
Sub botonpotencia
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(caja,"")
  operadorpotencia = 1
  Controls.SetTextBoxText(proceso, operador1 + "^")
EndSub
Sub botonpotenciadies
  operador1 = Controls.GetTextBoxText(caja)
  total = Math.Power(10,operador1)
  Controls.SetTextBoxText(caja,total)
  Controls.SetTextBoxText(proceso, "10^" + operador1 + " =")
EndSub
Sub botonlog
  operador1 = Controls.GetTextBoxText(caja)
  If operador1 = "" Or operador1 <= 0 Then
    Controls.SetTextBoxText(caja, "Error")
    Controls.SetTextBoxText(proceso, "log(inválido)")
  Else
    Controls.SetTextBoxText(proceso, "log(" + operador1 + ")" + " =")   
    operador1 = Math.Log(operador1)
    Controls.SetTextBoxText(caja, operador1)
  EndIf
EndSub
Sub botonln 
  operador1 = Controls.GetTextBoxText(caja)
  If operador1 = "" Or operador1 <= 0 Then
    Controls.SetTextBoxText(caja, "Error")
    Controls.SetTextBoxText(proceso, "ln(inválido)")
  Else
    Controls.SetTextBoxText(proceso, "ln(" + operador1 + ")" + " =")
    operador1 = Math.NaturalLog(operador1)
    Controls.SetTextBoxText(caja, operador1)
  EndIf
EndSub
Sub botonfraccion
  operador2 = Controls.GetTextBoxText(caja)
  operador1 = 1 / operador2
  Controls.SetTextBoxText(caja,operador1)
  Controls.SetTextBoxText(proceso, "1/" + operador2 + " =")
EndSub
Sub botonabsoluto
  If operador1 > 1 Then
    If operador1 < 0 Then
    Controls.SetTextBoxText(proceso, "|" + operador1 + "| =")
    operador1 = operador1 * (-1)
    Controls.SetTextBoxText(caja,operador1)
  Else
    Controls.SetTextBoxText(proceso, "|" + operador1 + "| =")
    Controls.SetTextBoxText(caja,operador1)
  EndIf
  Else
  operador1 = Controls.GetTextBoxText(caja)
  If operador1 < 0 Then
    Controls.SetTextBoxText(proceso, "|" + operador1 + "| =")
    operador1 = operador1 * (-1)
    Controls.SetTextBoxText(caja,operador1)
  Else
    Controls.SetTextBoxText(proceso, "|" + operador1 + "| =")
    Controls.SetTextBoxText(caja,operador1)
  EndIf
EndIf
EndSub
Sub botonfactorial
  operador1 = Controls.GetTextBoxText(caja)
  operador2 = 1
  For i = 1 To operador1
    operador2 = operador2 * i
  EndFor
  Controls.SetTextBoxText(caja, operador2 )
  Controls.SetTextBoxText(proceso, operador2 )
EndSub

'Botones Second
Sub botoncubo
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(proceso, operador1 + "³ = ")
  operador1 = operador1 * operador1 * operador1 
  Controls.SetTextBoxText(caja, operador1)
EndSub
Sub botonraiz3
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(proceso, "³√" + operador1 + " =" )
  operador1 = Math.Power(operador1, 1/3)
  Controls.SetTextBoxText(caja, operador1)
EndSub
Sub botonraizy
  operador1 = Controls.GetTextBoxText(caja)
  operadorraiz = 1
  Controls.SetTextBoxText(caja, "")
  Controls.SetTextBoxText(proceso, operador1 + "√")
EndSub
Sub botonpotenciados
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(proceso, "2^" + operador1 + " = " )
  operador1 = Math.Power(2,operador1)
  Controls.SetTextBoxText(caja,operador1)
EndSub
Sub botonlogy
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(caja, "")
  Controls.SetTextBoxText(proceso, "log_" + operador1 + "(")
  operadorlogy = 1
EndSub
Sub botonex
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(proceso,"e^" + operador1 + " =" )
  operador1 = Math.Power(2.7182818284590452353602874713527,operador1)
  Controls.SetTextBoxText(caja,operador1)
EndSub
Sub botonfracciony
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(caja, "")
  Controls.SetTextBoxText(proceso, operador1 + " / " )
  operadorfracciony = 1
EndSub
Sub botonpunto
  Controls.SetTextBoxText(caja, Text.Append(Controls.GetTextBoxText(caja), "."))
  Controls.SetTextBoxText(proceso, Text.Append(Controls.GetTextBoxText(proceso), ".")) 
EndSub
' OPERACIONES
Sub botonmas
  operador1 = Controls.GetTextBoxText(caja)
  If OperadorParentesis = 1 Then
  Controls.SetTextBoxText(caja, operador1)   
  Controls.SetTextBoxText(proceso, operador1 + " + " )
  Controls.SetTextBoxText(caja, "")
  Else
  Controls.SetTextBoxText(proceso, operador1 + " + " )
  operadorSuma = 1
  operadorResta = 0
  operadorMultiplicacion = 0
  operadorDivision = 0
  Controls.SetTextBoxText(caja, "")
EndIf
EndSub
Sub botonresta
  If OperadorParentesis = 1 Then
  Controls.SetTextBoxText(proceso, operador1)   
  Controls.SetTextBoxText(proceso, operador1 + " - " )
  EndIf
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(caja, "")
  Controls.SetTextBoxText(proceso, operador1 + " - " )
  operadorResta = 1
  operadorSuma = 0
  operadorMultiplicacion = 0
  operadorDivision = 0
EndSub

Sub botonMultiplicacion
  If OperadorParentesis = 1 Then
  Controls.SetTextBoxText(proceso, operador1)   
  Controls.SetTextBoxText(proceso, operador1 + " X " )
  EndIf
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(caja, "")
  Controls.SetTextBoxText(proceso, operador1 + " X " )
  operadorMultiplicacion = 1
  operadorSuma = 0
  operadorResta = 0
  operadorDivision = 0
EndSub

Sub botonDivision
  If OperadorParentesis = 1 Then
  Controls.SetTextBoxText(proceso, operador1)   
  Controls.SetTextBoxText(proceso, operador1 + " / " )
  EndIf
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(caja, "")
  Controls.SetTextBoxText(proceso, operador1 + " / " )
  operadorDivision = 1
  operadorSuma = 0
  operadorResta = 0
  operadorMultiplicacion = 0
EndSub

Sub botonBT
  operador1 = ""
  Controls.SetTextBoxText(caja, "")
  Controls.SetTextBoxText(proceso, "")
EndSub
Sub botonC
  contenido_caja = Controls.GetTextBoxText(caja)
  contenido_proceso = Controls.GetTextBoxText(proceso)
  largo = Text.GetLength(contenido_caja)
  largo2 = Text.GetLength(contenido_proceso)
 If largo > 0 Then
   caracter = Text.GetSubText(contenido_caja, 1, largo - 1)
   Controls.SetTextBoxText(caja,caracter)
   caracter2 = Text.GetSubText(contenido_caja, 1, largo - 1)
   Controls.SetTextBoxText(proceso,caracter2)
   EndIf
EndSub
Sub botonIgual
  operador2 = Controls.GetTextBoxText(caja)
  operacionRealizada = 0
  If operadorSuma = 1 Then
    total = operador1 + operador2
    Controls.SetTextBoxText(proceso, operador1 + " + " + operador2 + " = ")
    operadorSuma = 0 
    operacionRealizada = 1
  ElseIf operadorResta = 1 then
    total = operador1 - operador2
    Controls.SetTextBoxText(proceso, operador1 + " - " + operador2 + " = ")
    operadorResta = 0
    operacionRealizada = 1
  ElseIf operadorMultiplicacion = 1 then
    total = operador1 * operador2
    Controls.SetTextBoxText(proceso, operador1 + " X " + operador2 + " = ")
    operadorMultiplicacion = 0
    operacionRealizada = 1
  ElseIf operadorDivision = 1 then
    If operador2 = 0 Then
       Controls.SetTextBoxText(caja, "No se puede divir entre cero")
    Else
        total = operador1 / operador2
        Controls.SetTextBoxText(proceso, operador1 + " / " + operador2 + " = ")
    EndIf
    operadorDivision = 0
    operacionRealizada = 1
  EndIf
  If operadorpotencia = 1 Then
    total = Math.Power(operador1, operador2 )
    Controls.SetTextBoxText(proceso, operador1 + "^" + operador2 + " =")
    operadorpotencia = 0
    operacionRealizada = 1
  EndIf
  If OperadorParentesis = 1 Then
    total = Controls.GetTextBoxText(proceso)
    Controls.SetTextBoxText(caja, total)
  EndIf
  If operadorraiz = 1 Then
    total = Math.Power(operador2, 1/operador1)
    operadorraiz = 0
    operacionRealizada = 1
  EndIf
  If operadorlogy = 1 Then
    operador2 = Controls.GetTextBoxText(caja)
    total = Math.Log(operador1) / Math.Log(operador2)
    Controls.SetTextBoxText(proceso, "log_" + operador1 + "(" + operador2 + ") = ")
    operadorlogy = 0
    operacionRealizada = 1
  EndIf   
  If operadorfracciony = 1 Then
    operador2 = Controls.GetTextBoxText(caja)
    If operador2 = 0 Then
      Controls.SetTextBoxText(caja, "No se puede divir entre cero")
    Else
      Controls.SetTextBoxText(proceso, operador1 + " / " + operador2 + " = " )
    total = operador1 / operador2
    EndIf
    operadorfracciony = 0
    operacionRealizada = 1
  EndIf
  If operacionRealizada = 1 Then
    Controls.SetTextBoxText(caja, total)
  EndIf
EndSub