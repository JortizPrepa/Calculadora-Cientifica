Sub botonpunto
  contenido_caja =Controls.GetTextBoxText(caja)
  numero = "."

  Controls.SetTextBoxText(caja,text.Append(contenido_caja,numero)) 
EndSub

'Signos 
Sub botonmas
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(caja, "")
  operadorSuma = 1 'activo
EndSub
Sub botonresta
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(caja, "")
  operadorResta = 1 'activo
EndSub
Sub botonMultiplicacion
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(caja, "")
  operadorMultiplicacion = 1 'activo
EndSub
Sub botonDivision
  operador1 = Controls.GetTextBoxText(caja)
  Controls.SetTextBoxText(caja, "")
  operadorDivision = 1 'activo
EndSub
Sub botonBT
  operador1 = ""
  operador2 = ""
  Controls.SetTextBoxText(caja, "")
EndSub


Sub botonIgual
  If operadorSuma = 1 Then
    operador2 = Controls.GetTextBoxText(caja)
    total = operador1 + operador2
    Controls.SetTextBoxText(caja, "")
    Controls.SetTextBoxText(caja, total)
    operadorSuma = 0 'resetea
    operador1 = ""
    operador2 = ""
    total = ""
  EndIf
  If operadorResta = 1 Then
    operador2 = Controls.GetTextBoxText(caja)
    total = operador1 - operador2
    Controls.SetTextBoxText(caja, "")
    Controls.SetTextBoxText(caja, total)
    operadorResta = 0 'resetea
    operador1 = ""
    operador2 = ""
    total = ""
  EndIf
  If operadorMultiplicacion = 1 Then
    operador2 = Controls.GetTextBoxText(caja)
    total = operador1 * operador2
    Controls.SetTextBoxText(caja, "")
    Controls.SetTextBoxText(caja, total)
    operadorSuma = 0 'resetea
    operador1 = ""
    operador2 = ""
    total = ""
  EndIf
  If operadorDivision = 1 Then
    operador2 = Controls.GetTextBoxText(caja)
    total = operador1 / operador2
    Controls.SetTextBoxText(caja, "")
    Controls.SetTextBoxText(caja, total)
    operadorResta = 0 'resetea
    operador1 = ""
    operador2 = ""
    total = ""
  EndIf
  EndSub